NODE_ENV=development
PORT=5000

MONGODB_URI=
JWT_SECRET=your_key
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_key
JWT_REFRESH_EXPIRES_IN=30d

# Admin Registration Secret
ADMIN_SECRET=your_admin_registration_secret

# Email (Nodemailer - Gmail or SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587


EMAIL_USER=your_mail
EMAIL_PASS=your_app_password can create at >  https://myaccount.google.com/apppasswords by your_mail
EMAIL_FROM=TicketMaster <your_email@gmail.com>

CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5000
SEAT_HOLD_TTL_MINUTES=10
WAITLIST_OFFER_TTL_MINUTES=15
